# Copy this file to .env.backend on the server and fill in real values.

SESSION_SECRET=replace-with-a-long-random-secret
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
APP_BASE_URL=https://your-hostname
FRONTEND_BASE_URL=https://your-hostname
GEMINI_API_KEY=your-gemini-api-key

# SQLite persisted in docker volume mounted at /data
SQLITE_FILE=/data/database.db

# Optional Gemini tuning
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_SYSTEM_PROMPT=
# GEMINI_MAX_INLINE_BYTES=8388608

# Used by Caddyfile env substitution
APP_HOST=your-hostname
LETSENCRYPT_EMAIL=you@example.com
